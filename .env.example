# Logs: DEBUG, INFO, WARNING, ERROR (default: INFO)
# LOG_LEVEL=DEBUG

# Descobrir estrutura do modal 2FA: salva HTML/screenshot em debug/ quando não encontra o campo
# DEBUG_MODAL=1

# Gmail - código 2FA (sem setup script, só .env)
# 1. Crie senha de app: https://myaccount.google.com/apppasswords
# 2. Adicione abaixo (NÃO use a senha normal do Gmail)
#
GMAIL_USER=seu@email.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Águas de Manaus
AGUAS_CPF=01596670207
AGUAS_SENHA=sua_senha

# Opcional - se não forem capturados automaticamente
AGUAS_MATRICULA=1103385
AGUAS_SEQUENCIAL=886372
AGUAS_ZONA=1

# Educação Adventista (7edu) - parcelas escolares
# EDUCADVENTISTA_CPF=01596670207
# EDUCADVENTISTA_DATA_NASCIMENTO=16091993
# Formato data: dd/mm/yyyy ou ddmmyyyy
# EDUCADVENTISTA_BUSCAR_PIX=1  # busca código PIX (mais lento)
# EDUCADVENTISTA_VENCIMENTO=10/03/2026  # opcional: só processa parcelas com essa data de vencimento

# Amazonas Energia (luz) - login automático com reCAPTCHA via IA
# AMAZONAS_ENERGIA_CPF=12345678900
# AMAZONAS_ENERGIA_SENHA=sua_senha
# AMAZONAS_ENERGIA_UNIT_ID=991643
# AMAZONAS_ENERGIA_UNIT_IDS=991643,24988197
# OPENAI_API_KEY=sk-xxx  # para resolver reCAPTCHA automaticamente (headless)

# Banco (SQLite por padrão; PostgreSQL opcional)
# DATABASE_URL=sqlite:///atlasfetch.db
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/atlasfetch

# Agendamento (scraper + save no banco por referencia)
# 1. Ative: SCHEDULER_ENABLED=1
# 2. SCHEDULER_AGUAS_ENABLED=0  desabilita job água (útil para testar só escola/luz)
# 3. Configure: SCHEDULER_CRON = minuto hora dia mes dia_semana
# 3. Rode: make scheduler (em terminal separado)
#
# Exemplos SCHEDULER_CRON:
#   0 6 * * *       = todo dia às 6h
#   0 8 10 3 *      = dia 10 de março às 8h
#   30 7 25 12 *    = dia 25 de dezembro às 7h30
#   0 6 1 * *       = dia 1 de cada mês às 6h
#   */5 * * * *     = a cada 5 min (teste)
#
# SCHEDULER_ENABLED=1
# SCHEDULER_CRON=0 6 * * *