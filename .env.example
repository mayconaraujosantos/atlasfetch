# Logs: DEBUG, INFO, WARNING, ERROR (default: INFO)
# LOG_LEVEL=DEBUG

# Descobrir estrutura do modal 2FA: salva HTML/screenshot em debug/ quando não encontra o campo
# DEBUG_MODAL=1

# Gmail - automação do código de verificação (escolha UMA opção)
#
# OPÇÃO 1 - Gmail API (recomendado, sem senha de app):
#   1. Crie projeto em https://console.cloud.google.com/
#   2. Ative Gmail API, crie credenciais (Aplicativo de computador)
#   3. Salve como credentials.json na pasta do projeto
#   4. Execute: python setup_gmail_oauth.py (autorize uma vez)
#
# OPÇÃO 2 - IMAP com senha de app:
#   GMAIL_USER=seu@email.com
#   GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Águas de Manaus
AGUAS_CPF=01596670207
AGUAS_SENHA=sua_senha

# Opcional - se não forem capturados automaticamente
AGUAS_MATRICULA=1103385
AGUAS_SEQUENCIAL=886372
AGUAS_ZONA=1

# Banco (opcional - default: SQLite)
# DATABASE_URL=sqlite:///./atlasfetch.db
# DATABASE_URL=postgresql://user:pass@localhost/atlasfetch

# Agendamento (scraper + save no banco por referencia)
# SCHEDULER_ENABLED=1
# SCHEDULER_CRON=0 6 * * *
#   (minuto hora dia mes dia_semana - ex: 0 6 * * * = todo dia às 6h)
# Teste a cada 5 min: SCHEDULER_CRON=*/5 * * * *
# Ou use SCHEDULER_HOUR=6 e SCHEDULER_MINUTE=0
